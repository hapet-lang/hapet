public class Math
{
	public int InsideField;

	public Math(int a)
	{
		this.InsideField = a;
	}

	public Math(float a)
	{
		this.InsideField = (int)a;
	}
}

public static class Program
{
	public static int Main(string[] args)
	{
		int test = 5;
		Math math = new Math(test);
		int a = math.InsideField;

		float test2 = 6;
		Math math2 = new Math(test2);
		int a2 = math2.InsideField;

		int ab = a + a2;

		return ab;
	}
}