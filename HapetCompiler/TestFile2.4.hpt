public static class Program
{
	public static int Main(string[] args)
	{
		// byte[][] argv = new byte[3][4];
		/*
		byte[][] argv = new byte[3][4] 
		{
			new byte[3] { 0, 1, 2 },
			new byte[3] { 1, 1, 2 },
			new byte[3] { 2, 1, 2 },
			new byte[] { 2, 1, 3 },
		};

		int summ = 0;
