public static class Program
{
	public static int Main(string[] args)
	{
		// byte[][] argv = new byte[3][4];
		byte[][] argv = new byte[3][4] 
		{
			new byte[3] { 0, 1, 2 },
			new byte[3] { 1, 1, 2 },
			new byte[3] { 2, 1, 2 },
			new byte[] { 2, 1, 3 },
		};

		int summ = 0;
		for (int i = 0; i < 4; i += 1)
		{
			for (int j = 0; j < 3; j += 1)
			{
				summ += argv[i][j];
			}	
		}

		return summ;
	}
}