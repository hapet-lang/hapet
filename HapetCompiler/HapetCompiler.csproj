<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <OutputType>Exe</OutputType>
        <TargetFramework>net8.0</TargetFramework>
        <ImplicitUsings>enable</ImplicitUsings>
        <EnableNETAnalyzers>false</EnableNETAnalyzers>
        <AnalysisMode>AllEnabledByDefault</AnalysisMode>
        <Version>0.0.1</Version>
        <RuntimeIdentifier Condition="'$(RuntimeIdentifier)' == ''">win-x64</RuntimeIdentifier>
        <AssemblyName>hapet</AssemblyName>
    </PropertyGroup>

    <ItemGroup>
        <ProjectReference Include="..\HapetFrontend\HapetFrontend.csproj" />
        <ProjectReference Include="..\HapetPostPrepare\HapetPostPrepare.csproj" />
        <ProjectReference Include="..\HapetLastPrepare\HapetLastPrepare.csproj" />
        <ProjectReference Include="..\HapetBackend\HapetBackend.csproj" />
        <ProjectReference Include="..\HapetLsp\HapetLsp.csproj" />
    </ItemGroup>

    <ItemGroup>
        <PackageReference Include="Newtonsoft.Json" Version="13.0.3" />
    </ItemGroup>

    <ItemGroup>
        <Content Include="../build-resources/version.txt">
            <CopyToOutputDirectory>Always</CopyToOutputDirectory>
        </Content>
    </ItemGroup>

</Project>
