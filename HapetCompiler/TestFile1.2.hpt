public class Math
{
	public int InsideField;
	public int InsideField2 = 4;

	public float GetPi()
	{
		return 3.14 + (float)this.InsideField + (float)this.InsideField2;
	}
}

public static class Program
{
	public static int Main()
	{
		Math math = new Math();
		float b = math.GetPi();
		return (int)b;
	}
}