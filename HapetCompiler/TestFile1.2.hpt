public class Math
{
	public int InsideField1; // default value here (0)
	public int InsideField2 = 4;
	public int InsideField3; // inited when used

	public float GetPi()
	{
		this.InsideField3 = 1;
		return 3.14 + (float)this.InsideField1 + (float)this.InsideField2 + (float)this.InsideField3;
	}
}

public static class Program
{
	public static int Main()
	{
		Math math = new Math();
		float b = math.GetPi();
		b = b + 3.0;
		return (int)b;
	}
}