using System.Runtime.InteropServices;
using System.Text; 
using System; 
using SmallTestProject.Test; 
using TestProject.Sub; 
using System.Runtime;

public static class Program
{
	public static int Main(string[] args)
	{
		var a = new TestCls();
		var aH = new Holder();
		aH.Tst = a;
		aH.Tst.A = new int[] { 1, 2, 3 };

		//aH.Tst[1] = 555;
		//return aH.Tst[1];
		return aH.Tst.A[2];
	}
}

public class TestCls
{
	public int[] A { get; set; }

	public int this[int index]
	{
		get
		{
			return A[index];
		}
		set
		{
			A[index] = value;
		}
	}
}

public class Holder
{
	public TestCls Tst { get; set; }
}
