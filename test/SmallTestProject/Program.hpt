using System.Runtime.InteropServices;
using System.Text; 
using System; 
using SmallTestProject.Test; 
using TestProject.Sub; 
using System.Runtime;

public static class Program
{
	public static int Main(string[] args)
	{
		var a = new TestCls();
		a.A = 4;
		var b = new TestCls();
		b.A = 6;

		return a + b;
	}
}

public class TestCls
{
	public int A { get; set; }

	public static int operator +(TestCls a, TestCls b)
	{
		return a.A + b.A;
	}
}
