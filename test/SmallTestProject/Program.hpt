using System.Runtime.InteropServices;
using System.Text;
using System;
using System.Runtime;

public static class Program
{
    public static int Main(string[] args)
    {
        var bytes = UTF8Encoding.GetBytesUnsafe("AnimeTest %d %d %s");
        var bytes222 = UTF8Encoding.GetBytesUnsafe("AnimeTest cringe");
        return PrintF(bytes, 444, 5555, bytes222);
    }

    [DllImportAttribute("", "vprintf")]
    public static extern int PrintF(byte* format, arglist);
}