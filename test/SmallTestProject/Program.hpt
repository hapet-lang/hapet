using System.Runtime.InteropServices;
using System.Text; 
using System; 
using SmallTestProject.Test; 
using TestProject.Sub; 
using System.Runtime;

public static class Program
{
	public static int Main(string[] args)
	{
		var a = new GG();
		object b = (object)a;
		var a2 = (GG)b;
		return a.Field1 + a2.Field2 + b.GetHashCode();
	}
}

public interface IAnime
{
	void Cringe();
}

public struct GG : IAnime
{
	int Field1 { get; set; } = 5;
	int Field2 { get; set; } = 3;

	public override int GetHashCode()
	{
		return 333;
	}
}