using System.Runtime.InteropServices;
using System.Text;
using System;
using System.Runtime;

public static class Program
{
    public static int Main(string[] args)
    {
        var b = new Base();
        return b.AnimeTest<int>(14);
    }
}

public class Base
{
    public T AnimeTest<T>(T value)
    {
        T a = GetInt<T>(value);
        return a;

        static T GetInt<T>(T c)
        {
            return c;
        }
    }
}

