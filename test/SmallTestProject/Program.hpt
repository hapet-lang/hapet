using System.Runtime.InteropServices;
using System.Text;
using System;
using SmallTestProject.Test;
using TestProject.Sub;
using System.Runtime;

public static class Program
{
    public static int Main(string[] args)
    {
        AnimeDerived a = new AnimeDerived();
        a.Propa = 41;
        var b = a as AnimeBase;
        b.Propa = 12;
        return a.Propa;
    }
}

public class AnimeBase
{
    public int Propa { get; set; }

    public int Test()
    {
        return 33;
    }
}

public class AnimeDerived : AnimeBase
{
    public new int Propa { get; set; }

    public new int Test()
    {
        return 44;
    }
}
