using System.Runtime.InteropServices;
using System.Text; 
using SmallTestProject.Test; 
using TestProject.Sub; 
using System.Runtime;

public static class Program
{
	public static int Main(string[] args)
	{
		Derived dr222 = new Derived();
		var aaa = dr222 as ISoh;
		var aaa2 = dr222 as IBot;
		var aaa3 = dr222 as ILoh;
		//var aaa4 = dr222 as BaseCls;
		return aaa.AnimeSoh + aaa2.AnimeBot + aaa3.AnimeLoh;
	}
}

public interface IBot
{
	byte AnimeBot;
}

public interface ILoh
{
	short AnimeLoh;
}

public interface ISoh : ILoh, IBot
{
	int AnimeSoh;
}

public class BaseCls : ILoh
{
	public string Field1;

	public short AnimeLoh;

	public BaseCls(string ddd)
	{
		this.Field1 = ddd;
	}
}

public class Derived : BaseCls, ISoh, IBot
{
	public long Field2;

	public int AnimeSoh;

	public byte AnimeBot;

	public Derived() : base("dasdasd")
	{
		this.AnimeSoh = 444;
		this.AnimeBot = 2;
		this.AnimeLoh = 3;
	}
}
