using System.Collections.Generic;

public class Event<T>
{
    internal List<T> _delegates = new List<T>();

    public static void operator +(Event<T> me, T newDelegate)
    {
        me.Add(newDelegate);
    } 

    public void Add(T newDelegate)
    {
        _delegates.Add(newDelegate);
    }

    public static void operator -(Event<T> me, T oldDelegate)
    {
        me.Remove(oldDelegate);
    } 

    public void Remove(T oldDelegate)
    {
        _delegates.Remove(oldDelegate);
    }
}