using System.Runtime.InteropServices;

public static class Math
{
    public static int Min(int val1, int val2)
    {
        return (val1 <= val2) ? val1 : val2;
    }

    public static double Truncate(double d)
    {
        Marshal.ModF(d, &d);
        return d;
    }
}