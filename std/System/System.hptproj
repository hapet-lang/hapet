<Project>
	<PropertyGroup>
		<ProjectName>System</ProjectName>
		<ProjectVersion>1.0.0</ProjectVersion>
		<AllowUnsafeCode>true</AllowUnsafeCode>

		<OutputIrFile>true</OutputIrFile>
		<Optimization>0</Optimization>
		<Verbose>false</Verbose>

        <TargetFormat>Library</TargetFormat>
        <!--<TargetPlatform>win-x86</TargetPlatform>-->
	</PropertyGroup>
</Project>
