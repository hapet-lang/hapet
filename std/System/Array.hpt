using System.Collections;
using System.Collections.Generic;

/// This is a test comment
/// And this is another one
public struct Array
{
    public int Length { get; internal set; }
    internal void* Buffer { get; set; }

    private static class EmptyArray<T>
    {
        // this is the implementation of Array.Empty<T>()
        internal static readonly T[] Value = new T[0];
    }

    public static T[] Empty<T>()
    {
        return EmptyArray<T>.Value;
    }
}

public struct Array<T> : IList<T>
{
    public int Length { get; internal set; }
    internal T* Buffer { get; set; }

    public int Count { get { return Length; } }

    public T this[int index] 
    {
        get 
        {
            return Buffer[index];
        }
        set
        {
            Buffer[index] = value;
        }
    }

    public IList<T> GetRange(int index, int count)
    {
        if (index < 0)
        {
            // TODO: 
            // ThrowHelper.ThrowIndexArgumentOutOfRange_NeedNonNegNumException();
        }

        if (count < 0)
        {
            // TODO: 
            // ThrowHelper.ThrowArgumentOutOfRangeException(ExceptionArgument.count, ExceptionResource.ArgumentOutOfRange_NeedNonNegNum);
        }

        T[] newArr = new T[count];
        Array.Copy(this, index, newArr, 0, count);
        return newArr;
    }

    public bool Contains(T item)
    {
        return Length != 0 && IndexOf(item) >= 0;
    }

    public void CopyTo(T[] array, int index)
    {
        // Delegate rest of error checking to Array.Copy.
        Array.Copy(this, index, array, 0, Length);
    }

    public IEnumerator<T> GetEnumerator()
    {
        return Length == 0 ? EmptyEnumerator<T>.Instance : new ArrayEnumerator<T>(this);
    }

    public int IndexOf(T value)
    {
        return list.IndexOf(value);
    }

    public int LastIndexOf(T item)
    {
        return list.LastIndexOf(item);
    }

    protected IList<T> Items { get { return list; } }

    public bool IsReadOnly { get { return true; } }

    public void Add(T value)
    {
        // TODO:
        // ThrowHelper.ThrowNotSupportedException(ExceptionResource.NotSupported_ReadOnlyCollection);
    }

    public void AddRange(IEnumerable<T> collection)
