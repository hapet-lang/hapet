        return 0;
    }

    public bool IsSynchronized { get { return false; } }

    public object SyncRoot { get { return list is ICollection coll ? coll.SyncRoot : this; } }

    public bool IsFixedSize { get { return true; } }

    private static bool IsCompatibleObject(object value)
    {
        // Non-null values are fine.  Only accept nulls if T is a class or Nullable<U>.
        // Note that default(T) is not equal to null for value types except when T is Nullable<U>.
        return (value is T) || (value == null && default(T) == null);
    }
}

internal sealed class ArrayEnumerator : IEnumerator, ICloneable
{
    private Array _array;
    private int _index;

    internal ArrayEnumerator(Array array)
    {
        _array = array;
        _index = -1;
    }

    public object Clone()
    {
        // TODO:
        // return MemberwiseClone();
        return null;
    }

    public bool MoveNext()
    {
        int index = _index + 1;
        int length = _array.Length;
        if ((int)index >= length)
        {
            _index = (int)length;
            return false;
        }
        _index = index;
        return true;
    }

    public object Current
    {
        get
        {
            int index = _index;
            Array array = _array;

            if ((int)index >= array.Length)
            {
                if (index < 0)
                {
                    // TODO:
                    // ThrowHelper.ThrowInvalidOperationException_InvalidOperation_EnumNotStarted();
                }
                else
                {
                    // TODO:
                    // ThrowHelper.ThrowInvalidOperationException_InvalidOperation_EnumEnded();
                }
            }

            return array[index];
        }
    }

    public void Reset()
    {
        _index = -1;
    }

    public void Dispose()
    {
        Reset();
        _array = default;
    }
}

internal sealed class ArrayEnumerator<T> : IEnumerator<T>, ICloneable
{
    private Array<T> _array;
    private int _index;

    internal ArrayEnumerator(Array<T> array)
    {
        _array = array;
        _index = -1;
    }

    public object Clone()
    {
        // TODO:
        // return MemberwiseClone();
        return null;
    }

    public bool MoveNext()
    {
        int index = _index + 1;
        int length = _array.Length;
        if ((int)index >= length)
        {
            _index = (int)length;
            return false;
        }
        _index = index;
        return true;
    }

    public object IEnumerator.Current
    {
        get 
        {
            return Current;
        }
    }

    public T Current
    {
        get
        {
            int index = _index;
            Array<T> array = _array;

            if ((int)index >= array.Length)
            {
                if (index < 0)
                {
                    // TODO:
                    // ThrowHelper.ThrowInvalidOperationException_InvalidOperation_EnumNotStarted();
                }
                else
                {
                    // TODO:
                    // ThrowHelper.ThrowInvalidOperationException_InvalidOperation_EnumEnded();
                }
            }

            return array[index];
        }
    }

    public void Reset()
    {
        _index = -1;
    }

    public void Dispose()
    {
        Reset();
        _array = default;
    }
}
