using System;

[SuppressStaticCtorCallAttribute]
public class Encoding
{
    public static int GetByteCount(byte* chars)
    {
        if ((uintptr)chars == (uintptr)0)
            return 0;

        int charsAmount = 0;
        byte currChar = chars[charsAmount];
        while (currChar != 0)
        {
            charsAmount += 1;
            currChar = chars[charsAmount];
        }
        return charsAmount;
    }
}