using System;

[SuppressStaticCtorCallAttribute]
public static class Marshal
{
    [DllImportAttribute("", "malloc")]
    public static extern void* Malloc(int size);

    [DllImportAttribute("", "free")]
    public static extern void Free(void* ptr);

    [DllImportAttribute("", "llvm.va_start")]
    public static extern void VaStart(void* ptr);

    [DllImportAttribute("", "llvm.va_end")]
    public static extern void VaEnd(void* ptr);
}