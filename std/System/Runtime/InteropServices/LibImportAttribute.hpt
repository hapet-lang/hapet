using System;

[SuppressStaticCtorCall]
public sealed class LibImportAttribute : Attribute
{
    [Required]
    public string LibName;
    [Required]
    public string EntryPoint;
    // If suppress of low level dllimport required (won't generate dllimport in IR)
    public bool SuppressDllImportAttribute;

    public LibImportAttribute()
    {
    }
}